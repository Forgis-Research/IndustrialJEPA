        "### V15-EMA Encoder Collapse Diagnosis"
      ],
      "id": "b5e2cdd7"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Explain the collapse mechanism\n",
        "print(\"V15-EMA Architecture Issue:\")\n",
        "print()\n",
        "print(\"Context: encoder(x_{0:t})\")\n",
        "print(\"Target:  encoder(x_{0:t+k})  [full sequence]\")\n",
        "print()\n",
        "print(\"Problem: x_{0:t+k} CONTAINS x_{0:t} as a prefix.\")\n",
        "print(\"The prediction task ||pred(h_t, k) - h_{t+k}||_1 can be solved\")\n",
        "print(\"by learning h to represent 'global summary' (mean/std of sequence).\")\n",
        "print(\"Since x_{0:t} and x_{0:t+k} have similar global statistics for\")\n",
        "print(\"small k, the encoder collapses: h_t ~ h_{t+k} for most k.\")\n",
        "print()\n",
        "print(\"Evidence from pretraining diagnostics:\")\n",
        "print(\"  Loss drops to 0.0063 very fast (ep3-5)\")\n",
        "print(\"  PC1 explained variance = 0.777 (anisotropy = 1.9e15x)\")\n",
        "print(\"  Probe RMSE oscillates: 30.82 -> 41.18 -> 28.33 -> 24.47 at ep100\")\n",
        "print()\n",
        "print(\"V15-SIGReg should NOT have this problem:\")\n",
        "print(\"  SIGReg(h_t) directly penalizes anisotropy in encoder outputs\")\n",
        "print(\"  Even if prediction is 'easy', SIGReg forces isotropic distribution\")"
      ],
      "id": "1b482697",
      "execution_count": null,
      "outputs": []
