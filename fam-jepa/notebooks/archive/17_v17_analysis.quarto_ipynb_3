    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "import math\n",
        "rng = np.random.RandomState(0)\n",
        "K_max = 150\n",
        "n = 20000\n",
        "u = rng.uniform(0, math.log(K_max), size=n)\n",
        "k_log = np.exp(u).astype(int).clip(1, K_max)\n",
        "k_uni = rng.randint(5, 31, size=n)\n",
        "\n",
        "fig, axes = plt.subplots(1, 2, figsize=(10, 4))\n",
        "axes[0].hist(k_log, bins=50, color='tab:blue', alpha=0.7)\n",
        "axes[0].set_xlabel('k (horizon)'); axes[0].set_ylabel('count')\n",
        "axes[0].set_title(f'V17: LogUniform[1, {K_max}]')\n",
        "axes[0].set_xscale('log')\n",
        "\n",
        "axes[1].hist(k_uni, bins=30, color='tab:orange', alpha=0.7)\n",
        "axes[1].set_xlabel('k (horizon)'); axes[1].set_ylabel('count')\n",
        "axes[1].set_title('V2: Uniform[5, 30]')\n",
        "fig.tight_layout(); plt.savefig(PLOT_DIR / 'k_distribution.png'); plt.show()"
      ],
