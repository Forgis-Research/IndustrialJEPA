% neurips_2024.sty - Style file for NeurIPS 2024
% Based on the standard NeurIPS formatting
% Original authors: Roman Garnett, et al.

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{neurips_2024}[2024/05/01 NeurIPS 2024 submission style]

% Options
\newif\if@neuripsfinal\@neuripsfinalfalse
\newif\if@neuripspreprint\@neuripspreprintfalse
\newif\if@neuripsnonatbib\@neuripsnonatbibfalse

\DeclareOption{final}{\@neuripsfinaltrue}
\DeclareOption{preprint}{\@neuripspreprinttrue}
\DeclareOption{nonatbib}{\@neuripsnonatbibtrue}
\ProcessOptions\relax

% Required packages
\RequirePackage{geometry}
\geometry{
  textheight=9in,
  textwidth=5.5in,
  top=1in,
  headheight=12pt,
  headsep=25pt,
  footskip=30pt
}

\RequirePackage{fancyhdr}
\pagestyle{fancy}
\fancyhf{}
\fancyhead[C]{}
\fancyfoot[C]{\thepage}
\renewcommand{\headrulewidth}{0pt}

% Font setup
\RequirePackage{times}
\RequirePackage{microtype}

% Title formatting
\def\@maketitle{%
  \vbox to 0pt{}%
  \vskip -40pt
  \begin{center}%
    {\LARGE\bfseries \@title \par}%
    \vskip 0.3in minus 0.1in
    \if@neuripsfinal
      \begin{tabular}[t]{c}%
        \@author
      \end{tabular}%
    \else
      \if@neuripspreprint
        \begin{tabular}[t]{c}%
          \@author
        \end{tabular}%
      \else
        {Anonymous Author(s)}%
      \fi
    \fi
    \vskip 0.3in minus 0.1in
  \end{center}
}

% Abstract
\renewenvironment{abstract}{%
  \centerline{\large\bfseries Abstract}%
  \vspace{0.5ex}%
  \begin{quote}%
}{%
  \par%
  \end{quote}%
  \vskip 1ex%
}

% Section formatting
\RequirePackage[compact]{titlesec}
\titleformat{\section}{\large\bfseries}{\thesection}{1em}{}
\titleformat{\subsection}{\normalsize\bfseries}{\thesubsection}{1em}{}
\titleformat{\subsubsection}{\normalsize\itshape}{\thesubsubsection}{1em}{}

% Footnote formatting
\renewcommand{\footnoterule}{%
  \kern -3pt
  \hrule width 2in height 0.4pt
  \kern 2.6pt
}

% Bibliography
\if@neuripsnonatbib\else
  \RequirePackage[numbers,sort&compress]{natbib}
  \bibliographystyle{plainnat}
  \setlength{\bibsep}{2pt plus 1pt minus 1pt}
\fi

% Hyperref setup (load last)
\AtEndPreamble{%
  \@ifpackageloaded{hyperref}{}{%
    \RequirePackage[colorlinks=true,citecolor=blue,urlcolor=blue,linkcolor=blue]{hyperref}
  }
}

\endinput
